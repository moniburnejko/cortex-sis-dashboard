#!/usr/bin/env bash
# pre-commit hook - automatically sanitize sensitive snowflake object names
# in staged files before committing.
#
# setup: git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOKS_DIR="$REPO_ROOT/.githooks"
MAP_FILE="$HOOKS_DIR/.sanitize-map"

# if no map file exists, skip silently (user may not have set it up yet)
if [[ ! -f "$MAP_FILE" ]]; then
    exit 0
fi

# load mappings
REAL_NAMES=()
PLACEHOLDERS=()

while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue

    real="${line%%=*}"
    placeholder="${line#*=}"
    [[ -z "$real" || -z "$placeholder" ]] && continue

    REAL_NAMES+=("$real")
    PLACEHOLDERS+=("$placeholder")
done < "$MAP_FILE"

[[ ${#REAL_NAMES[@]} -gt 0 ]] || exit 0

# get staged files (added, copied, modified, renamed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
[[ -z "$STAGED_FILES" ]] && exit 0

MODIFIED=()

while IFS= read -r filepath; do
    [[ -z "$filepath" ]] && continue
    fullpath="$REPO_ROOT/$filepath"
    [[ -f "$fullpath" ]] || continue

    # skip binary files
    if file --mime-encoding "$fullpath" 2>/dev/null | grep -q "binary"; then
        continue
    fi

    file_changed=false

    for i in "${!REAL_NAMES[@]}"; do
        if grep -qF "${REAL_NAMES[$i]}" "$fullpath" 2>/dev/null; then
            perl -pi -e "s/\Q${REAL_NAMES[$i]}\E/${PLACEHOLDERS[$i]}/g" "$fullpath"
            file_changed=true
        fi
    done

    if [[ "$file_changed" == true ]]; then
        git add "$fullpath"
        MODIFIED+=("$filepath")
    fi
done <<< "$STAGED_FILES"

if [[ ${#MODIFIED[@]} -gt 0 ]]; then
    echo "[sanitize] replaced sensitive names in ${#MODIFIED[@]} file(s):"
    printf '  %s\n' "${MODIFIED[@]}"
fi

exit 0
